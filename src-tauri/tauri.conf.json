{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hue",
  "version": "0.0.23",
  "identifier": "com.takum.hue",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hue",
        "width": 1000,
        "height": 1000,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true
      },
      {
        "label": "preferences",
        "url": "/#preferences",
        "title": "Hue Preferences",
        "width": 400,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1NDAwQzY2RENEMzM1NzIKUldSeU5kUGNaZ3hBOVJxb3hPTVRJZEYwNDVVeWVmN1FQbU9IdVIrK3JmcTdDZ3F4c0dxaVBqV1IK",
      "endpoints": [
        "https://github.com/diny-hou/Hue/releases/latest/download/update.json"
      ],
      "dangerousInsecureTransportProtocol": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
